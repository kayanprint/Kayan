  <script type='text/javascript'>
    //<![CDATA[
    // تحديث عداد السلة
    function updateCartCount() {
      const cartCount = document.getElementById('cartCount');
      cartCount.textContent = cart.length;
    }
    
    // عرض/إخفاء السلة العائمة
    function toggleCart() {
      const floatingCart = document.getElementById('floatingCart');
      floatingCart.classList.toggle('show');
      if (floatingCart.classList.contains('show')) {
        displayCartItems();
      }
    }
    
    // عرض عناصر السلة
    function displayCartItems() {
      const cartItems = document.getElementById('cartItems');
      const cartTotal = document.getElementById('cartTotal');
      
      if (cart.length === 0) {
        cartItems.innerHTML = '<p>السلة فارغة</p>';
        cartTotal.textContent = '0';
        return;
      }
      
      let html = '';
      let total = 0;
      
      cart.forEach((item, index) => {
        html += `
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid #eee;">
            <div>
              <strong>${item.title}</strong><br>
              <small>${item.price} ج.م</small>
            </div>
            <button onclick="removeFromCart(${index})" style="background: #dc3545; color: white; border: none; border-radius: 3px; padding: 0.25rem 0.5rem; cursor: pointer;">
              حذف
            </button>
          </div>
        `;
        total += parseFloat(item.price);
      });
      
      cartItems.innerHTML = html;
      cartTotal.textContent = total.toFixed(2);
    }
    
    // إضافة منتج للسلة
    function addToCart(title, price, image, url) {
      const item = {
        title: title,
        price: price,
        image: image,
        url: url,
        id: Date.now()
      };
      
      cart.push(item);
      localStorage.setItem('kayanCart', JSON.stringify(cart));
      updateCartCount();
      
      // إظهار رسالة تأكيد
      alert('تم إضافة المنتج إلى السلة بنجاح!');
    }
    
    // حذف منتج من السلة
    function removeFromCart(index) {
      cart.splice(index, 1);
      localStorage.setItem('kayanCart', JSON.stringify(cart));
      updateCartCount();
      displayCartItems();
    }
    
    // البحث في المنتجات
    function searchProducts() {
      const searchTerm = document.getElementById('searchInput').value;
      if (searchTerm.trim()) {
        window.location.href = '/search?q=' + encodeURIComponent(searchTerm);
      }
    }
    
    // إتمام الطلب
    function proceedToCheckout() {
      if (cart.length === 0) {
        alert('السلة فارغة! يرجى إضافة منتجات أولاً.');
        return;
      }
      
      // سيتم تطوير صفحة الدفع في المرحلة التالية
      alert('سيتم توجيهك لصفحة إتمام الطلب...');
      // window.location.href = '/checkout';
    }
    
    // تحميل المنتجات من مقالات بلوجر
    function loadProducts() {
      // سيتم تطوير هذه الوظيفة في المرحلة التالية
      console.log('تحميل المنتجات...');
    }
    
    // تهيئة الصفحة
    document.addEventListener('DOMContentLoaded', function() {
      updateCartCount();
      loadProducts();
      
      // إضافة مستمع للبحث عند الضغط على Enter
      document.getElementById('searchInput').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
          searchProducts();
        }
      });
    });
    
    // إغلاق السلة عند النقر خارجها
    document.addEventListener('click', function(e) {
      const floatingCart = document.getElementById('floatingCart');
      const cartIcon = document.querySelector('.cart-icon');
      
      if (!floatingCart.contains(e.target) && !cartIcon.contains(e.target)) {
        floatingCart.classList.remove('show');
      }
    });
    //]]>
  </script>
  
