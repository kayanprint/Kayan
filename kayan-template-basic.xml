  <!-- Header -->
  <header class='header'>
    <div class='header-top'>
      <div class='container'>
        <div class='contact-info'>
          <span>📞 01121499017</span>
          <span>📧 info@kayanprint.com</span>
          <span>📍 مصر - جميع المحافظات</span>
        </div>
      </div>
    </div>
    
    <div class='container'>
      <div class='header-content'>
        <a href='/' class='logo'>مكتبة ومطبعة كيان</a>
        
        <div class='search-cart'>
          <div class='search-box'>
            <input type='text' placeholder='ابحث عن المنتجات...' id='searchInput'/>
            <button class='search-btn' onclick='searchProducts()'>🔍</button>
          </div>
          
          <div class='cart-icon' onclick='toggleCart()'>
            🛒
            <span class='cart-count' id='cartCount'>0</span>
          </div>
        </div>
      </div>
    </div>
    
    <nav class='nav'>
      <div class='container'>
        <ul class='nav-menu'>
          <li><a href='/'>الرئيسية</a></li>
          <li><a href='/search/label/طباعة'>خدمات الطباعة</a></li>
          <li><a href='/search/label/مكتبة'>المكتبة</a></li>
          <li><a href='/search/label/تصميم'>التصميم</a></li>
          <li><a href='/p/about.html'>من نحن</a></li>
          <li><a href='/p/contact.html'>اتصل بنا</a></li>
        </ul>
      </div>
    </nav>
  </header>

  <!-- Main Content -->
  <main class='container'>
    <div class='main-content'>
      <!-- Products Section -->
      <section class='products-section'>
        <b:section class='main' id='main' maxwidgets='1' showaddelement='no'>
          <b:widget id='Blog1' locked='true' title='Blog Posts' type='Blog' version='1' visible='true'>
            <b:widget-settings>
              <b:widget-setting name='showDateHeader'>false</b:widget-setting>
              <b:widget-setting name='style.textcolor'>#000000</b:widget-setting>
              <b:widget-setting name='showShareButtons'>false</b:widget-setting>
            </b:widget-settings>
            <b:includable id='main'>
              <div class='products-grid' id='productsGrid'>
                <b:loop values='data:posts' var='post'>
                  <article class='product-card' expr:data-labels='data:post.labels'>
                    <img class='product-image' expr:alt='data:post.title' expr:src='data:post.featuredImage'/>
                    <div class='product-info'>
                      <h3 class='product-title'><data:post.title/></h3>
                      <div class='product-price' expr:data-price='data:post.body'>
                        <script>
                          // استخراج السعر من المحتوى
                          var content = '<data:post.body/>';
                          var priceMatch = content.match(/(\d+)\s*جنيه/);
                          var price = priceMatch ? priceMatch[1] : '0';
                          document.write(price + ' جنيه');
                        </script>
                      </div>
                      <button class='add-to-cart' expr:onclick='&quot;addToCart(&apos;&quot; + data:post.title + &quot;&apos;, &apos;&quot; + data:post.featuredImage + &quot;&apos;, &apos;&quot; + data:post.url + &quot;&apos;)&quot;'>
                        إضافة للسلة
                      </button>
                    </div>
                  </article>
                </b:loop>
              </div>
              
              <!-- Ad between products -->
              <div class='ad-container' style='margin: 30px 0;'>
                <div class='ad-label'>إعلان</div>
                <ins class='adsbygoogle'
                     style='display:block'
                     data-ad-client='ca-pub-XXXXXXXXXX'
                     data-ad-slot='XXXXXXXXXX'
                     data-ad-format='auto'></ins>
              </div>
            </b:includable>
          </b:widget>
        </b:section>
      </section>

      <!-- Sidebar -->
      <aside class='sidebar'>
        <!-- Categories -->
        <div class='sidebar-section'>
          <h3>التصنيفات</h3>
          <ul class='categories'>
            <li><a href='/search/label/طباعة'>خدمات الطباعة</a></li>
            <li><a href='/search/label/مكتبة'>أدوات مكتبية</a></li>
            <li><a href='/search/label/تصميم'>خدمات التصميم</a></li>
            <li><a href='/search/label/كتب'>الكتب</a></li>
            <li><a href='/search/label/هدايا'>الهدايا</a></li>
          </ul>
        </div>
        
        <!-- Sidebar Ad -->
        <div class='ad-container' style='margin-top: 30px;'>
          <div class='ad-label'>إعلان</div>
          <ins class='adsbygoogle'
               style='display:block;width:300px;height:600px'
               data-ad-client='ca-pub-XXXXXXXXXX'
               data-ad-slot='XXXXXXXXXX'></ins>
        </div>
      </aside>
    </div>
  </main>

  <!-- Cart Sidebar -->
  <div class='cart-sidebar' id='cartSidebar'>
    <div class='cart-header'>
      <h3>سلة التسوق</h3>
      <button class='close-cart' onclick='toggleCart()'>×</button>
    </div>
    
    <div class='cart-items' id='cartItems'>
      <!-- Cart items will be populated by JavaScript -->
    </div>
    
    <div class='cart-total'>
      <div class='total-row'>
        <span>المجموع الفرعي:</span>
        <span id='subtotal'>0 جنيه</span>
      </div>
      <div class='total-row'>
        <span>الشحن:</span>
        <span id='shipping'>يحسب عند الطلب</span>
      </div>
      <div class='total-row' style='font-weight: bold; font-size: 1.2rem;'>
        <span>المجموع الكلي:</span>
        <span id='total'>0 جنيه</span>
      </div>
      
      <button class='checkout-btn' onclick='proceedToCheckout()'>
        إتمام الطلب
      </button>
    </div>
  </div>

  <!-- Footer -->
  <footer class='footer'>
